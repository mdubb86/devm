# Managed by devm. Regenerated on VM lifecycle events; hand edits will be
# overwritten. Include from ~/.ssh/config as:
#     Include "~/Library/Application Support/devm/ssh_config"

Host devm-alpha
    HostName             127.0.0.1
    User                 devm
    Port                 2201
    IdentityFile         "{{RUNTIME_DIR}}/ssh/projects/alpha/id_ed25519"
    UserKnownHostsFile   "{{RUNTIME_DIR}}/ssh/projects/alpha/known_hosts"
    HostKeyAlias         devm-alpha
    StrictHostKeyChecking yes
    IdentitiesOnly       yes

Host devm-bravo
    HostName             127.0.0.1
    User                 devm
    Port                 2202
    IdentityFile         "{{RUNTIME_DIR}}/ssh/projects/bravo/id_ed25519"
    UserKnownHostsFile   "{{RUNTIME_DIR}}/ssh/projects/bravo/known_hosts"
    HostKeyAlias         devm-bravo
    StrictHostKeyChecking yes
    IdentitiesOnly       yes

Host devm-charlie
    HostName             127.0.0.1
    User                 devm
    Port                 2203
    IdentityFile         "{{RUNTIME_DIR}}/ssh/projects/charlie/id_ed25519"
    UserKnownHostsFile   "{{RUNTIME_DIR}}/ssh/projects/charlie/known_hosts"
    HostKeyAlias         devm-charlie
    StrictHostKeyChecking yes
    IdentitiesOnly       yes

