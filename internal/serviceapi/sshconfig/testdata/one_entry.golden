# Managed by devm. Regenerated on VM lifecycle events; hand edits will be
# overwritten. Include from ~/.ssh/config as:
#     Include "~/Library/Application Support/devm/ssh_config"

Host devm-myproj-vm
    HostName             192.168.64.7
    User                 devm
    Port                 22
    IdentityFile         "{{RUNTIME_DIR}}/ssh/projects/myproj/id_ed25519"
    UserKnownHostsFile   "{{RUNTIME_DIR}}/ssh/projects/myproj/known_hosts"
    HostKeyAlias         devm-myproj-vm
    StrictHostKeyChecking yes
    IdentitiesOnly       yes

