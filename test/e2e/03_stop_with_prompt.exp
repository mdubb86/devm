#!/usr/bin/env expect -f
source [file dirname [info script]]/lib/common.exp

set timeout 120
set test_name "03_stop_with_prompt"

lassign [e2e_setup_workspace "stop-prompt"] sb ws
cd $ws

# Bring sandbox up with a user shell.
spawn [e2e_devm_path] shell
set shell_id $spawn_id
expect {
    -i $shell_id
    -re $::e2e_prompt_re { }
    timeout { e2e_fail $test_name "shell never reached prompt" }
    eof { e2e_fail $test_name "shell exited before prompt" }
}

# Spawn `devm stop` in a separate process.
spawn [e2e_devm_path] stop
set stop_id $spawn_id

# Expect the confirmation prompt:
# "Stop sandbox <name>? This will hang up N session(s). [y/N]: "
expect {
    -i $stop_id
    -re "Stop sandbox $sb\\?.+\\\[y/N\\\]: " { }
    timeout { e2e_fail $test_name "stop never produced prompt" }
    eof { e2e_fail $test_name "stop exited before prompt" }
}

# Approve.
send -i $stop_id "y\r"
expect {
    -i $stop_id
    eof { }
    timeout { e2e_fail $test_name "stop did not exit after approval" }
}

# The user shell should also exit (sandbox died → bash session killed).
expect {
    -i $shell_id
    eof { }
    timeout { e2e_fail $test_name "user shell did not exit after stop" }
}

# Sandbox state: stopped.
e2e_assert_sandbox_state $sb "stopped"

e2e_pass $test_name
