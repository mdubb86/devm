#!/usr/bin/env expect -f
source [file dirname [info script]]/lib/common.exp

set timeout 120
set test_name "04_stop_with_yes"

lassign [e2e_setup_workspace "stop-yes"] sb ws
cd $ws

# Bring sandbox up.
spawn [e2e_devm_path] shell
set shell_id $spawn_id
expect {
    -i $shell_id
    -re $::e2e_prompt_re { }
    timeout { e2e_fail $test_name "shell never reached prompt" }
    eof { e2e_fail $test_name "shell exited before prompt" }
}

# Run `devm stop --yes` — should not prompt.
spawn [e2e_devm_path] stop --yes
set stop_id $spawn_id

# Should NOT see the prompt — just exit cleanly.
expect {
    -i $stop_id
    -re "\\\[y/N\\\]:" {
        e2e_fail $test_name "stop --yes incorrectly prompted"
    }
    eof { }
    timeout { e2e_fail $test_name "stop --yes did not exit" }
}

# User shell dies; sandbox stops.
expect {
    -i $shell_id
    eof { }
    timeout { e2e_fail $test_name "user shell did not exit after stop --yes" }
}
e2e_assert_sandbox_state $sb "stopped"

e2e_pass $test_name
