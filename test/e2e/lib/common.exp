# test/e2e/lib/common.exp
#
# Shared helpers for devm e2e expect tests.
#
# All scripts source this and start with `e2e_setup_workspace <slug>`,
# which registers cleanup via Tcl's exit trap AND writes to the bash
# driver's cleanup registry (see run-all.sh). Two-layer cleanup means
# even if the expect process is SIGKILLed, the bash trap still sweeps.

# Return the path to the devm binary. Defaults to ~/workspace/devm/devm
# if $DEVM_BIN is unset.
proc e2e_devm_path {} {
    if {[info exists ::env(DEVM_BIN)] && $::env(DEVM_BIN) ne ""} {
        return $::env(DEVM_BIN)
    }
    return "$::env(HOME)/workspace/devm/devm"
}

# Bash prompt pattern from the sbx-templates:shell agent.
# Verified shape: `agent@e2e-sbx:workspace$` (basename cwd, optional
# trailing space — accept either to be safe across template versions).
# All tests reference $::e2e_prompt_re instead of hardcoding the regex.
set ::e2e_prompt_re {agent@\S+:\S+\$ ?}

# Default expect timeout and global fallback handlers. Individual
# `expect { ... }` blocks with explicit timeout/eof clauses override
# these for that block; this block catches the "test author forgot
# to write handlers" case so a missing pattern fails loudly instead
# of silently passing.
set timeout 30
expect_after {
    timeout {
        e2e_fail "expect" "global timeout — no explicit timeout handler in expect block"
    }
    eof {
        e2e_fail "expect" "global eof — no explicit eof handler in expect block"
    }
}

# Append a registry entry: <sandbox>\t<workspace>\n
proc _e2e_registry_add {sb ws} {
    if {![info exists ::env(E2E_REGISTRY)]} {
        return
    }
    set fd [open $::env(E2E_REGISTRY) "a"]
    puts $fd "$sb\t$ws"
    close $fd
}

# Remove an entry (by sandbox name) from the registry. Best-effort.
proc _e2e_registry_remove {sb} {
    if {![info exists ::env(E2E_REGISTRY)]} {
        return
    }
    set reg $::env(E2E_REGISTRY)
    if {![file exists $reg]} {
        return
    }
    set fd [open $reg r]
    set contents [read $fd]
    close $fd
    set lines [split [string trimright $contents "\n"] "\n"]
    set kept {}
    foreach line $lines {
        if {$line eq ""} {
            continue
        }
        set parts [split $line "\t"]
        if {[lindex $parts 0] ne $sb} {
            lappend kept $line
        }
    }
    set fd [open $reg w]
    foreach line $kept {
        puts $fd $line
    }
    close $fd
}

# Create a unique workspace + sandbox name, write a minimal devm.yaml,
# run `devm reconcile` to render .devm/. Register cleanup. Return
# [list sandbox workspace].
#
# Optional second arg `yaml_extra` is appended to the default minimal
# devm.yaml (e.g. to add services for test 07).
proc e2e_setup_workspace {slug {yaml_extra ""}} {
    set rand [format "%04x" [expr {int(rand() * 65536)}]]
    set sandbox "e2e-test-$slug-$rand"
    set workspace "/tmp/devm-e2e-$slug-$rand"

    # Register BEFORE creating anything so bash trap can sweep on any
    # subsequent failure.
    _e2e_registry_add $sandbox $workspace

    # Set up Tcl exit handler for the per-test happy path.
    set ::e2e_active_sandbox $sandbox
    set ::e2e_active_workspace $workspace
    # Tracked in globals so the overridden 'exit' (below) can invoke cleanup.

    # Build workspace + minimal devm.yaml.
    exec mkdir -p $workspace
    set yaml "project:\n  id: $slug\n  sandbox_name: $sandbox\n  hostname_apex: $slug.local\n  port_offset: 51000\nbase_image:\n  docker: false\n$yaml_extra"
    set fd [open "$workspace/devm.yaml" "w"]
    puts -nonewline $fd $yaml
    close $fd

    # Render .devm/. devm reconcile reads cwd, so we cd in first.
    cd $workspace
    if {[catch {exec [e2e_devm_path] reconcile} err]} {
        e2e_fail "setup" "devm reconcile failed: $err"
    }

    return [list $sandbox $workspace]
}

# Override `exit` to run cleanup before exiting. Tcl/expect lets us
# rename + replace built-ins.
rename exit _e2e_original_exit
proc exit {{code 0}} {
    if {[info exists ::e2e_active_sandbox]} {
        e2e_cleanup $::e2e_active_sandbox $::e2e_active_workspace
        unset ::e2e_active_sandbox
        unset ::e2e_active_workspace
    }
    _e2e_original_exit $code
}

# Run sbx rm + remove workspace dir + unregister from registry.
# Best-effort; never fails.
proc e2e_cleanup {sb ws} {
    catch {exec sbx rm $sb}
    catch {exec rm -rf $ws}
    _e2e_registry_remove $sb
}

# Assert that `sbx ls` shows the sandbox in the given state. Polls for
# up to 10s to allow state transitions. Fails the test loudly.
proc e2e_assert_sandbox_state {sb expected} {
    set deadline [expr {[clock milliseconds] + 10000}]
    while {[clock milliseconds] < $deadline} {
        if {[catch {exec sbx ls} out]} {
            set out ""
        }
        foreach line [split $out "\n"] {
            set fields [regexp -all -inline {\S+} $line]
            if {[llength $fields] >= 3 && [lindex $fields 0] eq $sb} {
                if {[lindex $fields 2] eq $expected} {
                    return
                }
            }
        }
        after 250
    }
    e2e_fail "assert_state" "sandbox $sb never reached state '$expected' within 10s"
}

# Assert that the sandbox does NOT appear in `sbx ls`.
proc e2e_assert_sandbox_absent {sb} {
    set deadline [expr {[clock milliseconds] + 5000}]
    while {[clock milliseconds] < $deadline} {
        if {[catch {exec sbx ls} out]} {
            set out ""
        }
        set found 0
        foreach line [split $out "\n"] {
            set fields [regexp -all -inline {\S+} $line]
            if {[llength $fields] >= 1 && [lindex $fields 0] eq $sb} {
                set found 1
                break
            }
        }
        if {!$found} {
            return
        }
        after 250
    }
    e2e_fail "assert_absent" "sandbox $sb still listed by sbx ls after 5s"
}

# Poll `sbx ports <sb> --json` for up to 5s waiting for $needle to
# appear in the output. The sbx daemon's publish/list state can lag
# briefly behind a successful `sbx ports --publish`, so a single
# point-query is flaky. Fails the test if the needle never appears.
proc e2e_assert_ports_contain {sb needle} {
    set deadline [expr {[clock milliseconds] + 5000}]
    set last ""
    while {[clock milliseconds] < $deadline} {
        if {[catch {exec sbx ports $sb --json} out]} {
            set out ""
        }
        set last $out
        if {[string first $needle $out] >= 0} {
            return
        }
        after 250
    }
    e2e_fail "assert_ports" "port mapping containing '$needle' not seen within 5s (last: $last)"
}

proc e2e_pass {name} {
    puts "PASS: $name"
    exit 0
}

proc e2e_fail {name reason} {
    puts stderr "FAIL: $name: $reason"
    exit 1
}
