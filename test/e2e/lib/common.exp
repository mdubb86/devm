# test/e2e/lib/common.exp
#
# Shared helpers for devm e2e expect tests.
#
# All scripts source this and start with `e2e_setup_workspace <slug>`,
# which registers cleanup via Tcl's exit trap AND writes to the bash
# driver's cleanup registry (see run-all.sh). Two-layer cleanup means
# even if the expect process is SIGKILLed, the bash trap still sweeps.

# Return the path to the devm binary. Defaults to ~/workspace/devm/devm
# if $DEVM_BIN is unset.
proc e2e_devm_path {} {
    if {[info exists ::env(DEVM_BIN)] && $::env(DEVM_BIN) ne ""} {
        return $::env(DEVM_BIN)
    }
    return "$::env(HOME)/workspace/devm/devm"
}

# Bash prompt pattern from the sbx-templates:shell agent.
# Verified shape: `agent@e2e-sbx:workspace$` (basename cwd, optional
# trailing space — accept either to be safe across template versions).
# All tests reference $::e2e_prompt_re instead of hardcoding the regex.
set ::e2e_prompt_re {agent@\S+:\S+\$ ?}

# Default expect timeout. We deliberately do NOT install a global
# expect_after timeout/eof net: expect_after binds its patterns to the
# spawn_id active at definition time (the original stdin, exp0), not
# the test's later `spawn`ed processes. With multiple spawns it fires
# spuriously and masks the real per-block failure (and the message is
# unhelpful). Every test's `expect` blocks MUST therefore include
# explicit `timeout` and `eof` clauses that call e2e_fail.
set timeout 30

# Append a registry entry: <sandbox>\t<workspace>\n
proc _e2e_registry_add {sb ws} {
    if {![info exists ::env(E2E_REGISTRY)]} {
        return
    }
    set fd [open $::env(E2E_REGISTRY) "a"]
    puts $fd "$sb\t$ws"
    close $fd
}

# Remove an entry (by sandbox name) from the registry. Best-effort.
proc _e2e_registry_remove {sb} {
    if {![info exists ::env(E2E_REGISTRY)]} {
        return
    }
    set reg $::env(E2E_REGISTRY)
    if {![file exists $reg]} {
        return
    }
    set fd [open $reg r]
    set contents [read $fd]
    close $fd
    set lines [split [string trimright $contents "\n"] "\n"]
    set kept {}
    foreach line $lines {
        if {$line eq ""} {
            continue
        }
        set parts [split $line "\t"]
        if {[lindex $parts 0] ne $sb} {
            lappend kept $line
        }
    }
    set fd [open $reg w]
    foreach line $kept {
        puts $fd $line
    }
    close $fd
}

# Create a unique workspace + sandbox name, write a minimal devm.yaml,
# run `devm reconcile` to render .devm/. Register cleanup. Return
# [list sandbox workspace].
#
# Optional second arg `yaml_extra` is appended to the default minimal
# devm.yaml (e.g. to add services for test 07).
proc e2e_setup_workspace {slug {yaml_extra ""}} {
    set rand [format "%04x" [expr {int(rand() * 65536)}]]
    set sandbox "e2e-test-$slug-$rand"
    set workspace "/tmp/devm-e2e-$slug-$rand"

    # Register BEFORE creating anything so bash trap can sweep on any
    # subsequent failure.
    _e2e_registry_add $sandbox $workspace

    # Set up Tcl exit handler for the per-test happy path.
    set ::e2e_active_sandbox $sandbox
    set ::e2e_active_workspace $workspace
    # Tracked in globals so the overridden 'exit' (below) can invoke cleanup.

    # Build workspace + minimal devm.yaml.
    exec mkdir -p $workspace
    set yaml "project:\n  id: $slug\n  sandbox_name: $sandbox\n  hostname_apex: $slug.local\n  port_offset: 51000\nbase_image:\n  docker: false\n$yaml_extra"
    set fd [open "$workspace/devm.yaml" "w"]
    puts -nonewline $fd $yaml
    close $fd

    # Render .devm/. devm reconcile reads cwd, so we cd in first.
    cd $workspace
    if {[catch {exec [e2e_devm_path] reconcile} err]} {
        e2e_fail "setup" "devm reconcile failed: $err"
    }

    return [list $sandbox $workspace]
}

# Override `exit` to run cleanup before exiting. Tcl/expect lets us
# rename + replace built-ins.
rename exit _e2e_original_exit
proc exit {{code 0}} {
    if {[info exists ::e2e_active_sandbox]} {
        e2e_cleanup $::e2e_active_sandbox $::e2e_active_workspace
        unset ::e2e_active_sandbox
        unset ::e2e_active_workspace
    }
    _e2e_original_exit $code
}

# Register a global network policy (added via reconcile) for cleanup.
# sbx policies are GLOBAL and persist across sandboxes / sbx rm, so a
# test that adds one must remove it or it leaks into every future
# sandbox. Tracked both in a Tcl global (normal-exit cleanup) and in
# the bash registry (crash/SIGKILL sweep). $domain is the resource
# string passed to `sbx policy allow network`.
proc e2e_register_policy {domain} {
    lappend ::e2e_cleanup_policies $domain
    if {[info exists ::env(E2E_REGISTRY)]} {
        set fd [open $::env(E2E_REGISTRY) "a"]
        puts $fd "policy\t$domain"
        close $fd
    }
}

# Run sbx rm + remove workspace dir + remove any registered global
# policies + unregister from registry. Best-effort; never fails.
proc e2e_cleanup {sb ws} {
    catch {exec sbx rm $sb}
    catch {exec rm -rf $ws}
    if {[info exists ::e2e_cleanup_policies]} {
        foreach domain $::e2e_cleanup_policies {
            catch {exec sbx policy rm network --resource $domain}
        }
    }
    _e2e_registry_remove $sb
}

# Assert that `sbx ls` shows the sandbox in the given state. Polls for
# up to 10s to allow state transitions. Fails the test loudly.
proc e2e_assert_sandbox_state {sb expected} {
    set deadline [expr {[clock milliseconds] + 10000}]
    while {[clock milliseconds] < $deadline} {
        if {[catch {exec sbx ls} out]} {
            set out ""
        }
        foreach line [split $out "\n"] {
            set fields [regexp -all -inline {\S+} $line]
            if {[llength $fields] >= 3 && [lindex $fields 0] eq $sb} {
                if {[lindex $fields 2] eq $expected} {
                    return
                }
            }
        }
        after 250
    }
    e2e_fail "assert_state" "sandbox $sb never reached state '$expected' within 10s"
}

# Assert that the sandbox does NOT appear in `sbx ls`.
proc e2e_assert_sandbox_absent {sb} {
    set deadline [expr {[clock milliseconds] + 5000}]
    while {[clock milliseconds] < $deadline} {
        if {[catch {exec sbx ls} out]} {
            set out ""
        }
        set found 0
        foreach line [split $out "\n"] {
            set fields [regexp -all -inline {\S+} $line]
            if {[llength $fields] >= 1 && [lindex $fields 0] eq $sb} {
                set found 1
                break
            }
        }
        if {!$found} {
            return
        }
        after 250
    }
    e2e_fail "assert_absent" "sandbox $sb still listed by sbx ls after 5s"
}

# Poll `sbx ports <sb> --json` for up to 30s waiting for $needle to
# appear in the output. The sbx daemon's publish→list visibility lag
# can be substantial right after cold start (empirically >5s on a
# minimal sandbox). Fails the test if the needle never appears.
proc e2e_assert_ports_contain {sb needle} {
    set deadline [expr {[clock milliseconds] + 30000}]
    set last ""
    while {[clock milliseconds] < $deadline} {
        if {[catch {exec sbx ports $sb --json} out]} {
            set out ""
        }
        set last $out
        if {[string first $needle $out] >= 0} {
            return
        }
        after 250
    }
    e2e_fail "assert_ports" "port mapping containing '$needle' not seen within 30s (last: $last)"
}

# Poll `sbx ports <sb> --json` for up to 30s waiting for $needle to
# DISAPPEAR (used to verify an unpublish took effect). Fails if the
# needle is still present after the budget.
proc e2e_assert_ports_absent {sb needle} {
    set deadline [expr {[clock milliseconds] + 30000}]
    set last ""
    while {[clock milliseconds] < $deadline} {
        if {[catch {exec sbx ports $sb --json} out]} {
            set out ""
        }
        set last $out
        if {[string first $needle $out] < 0} {
            return
        }
        after 250
    }
    e2e_fail "assert_ports_absent" "port mapping containing '$needle' still present after 30s (last: $last)"
}

# Print the wall-clock delta since the previous e2e_phase call (and
# since the first), to stdout. Lets a test break its total runtime
# into named phases (cold start, reconcile, fresh shell, ...) so we
# can see where the time goes. Pure Tcl clock — no devm/stderr, so it
# can't trip Tcl's exec strictness.
proc e2e_phase {label} {
    set now [clock milliseconds]
    if {![info exists ::e2e_phase_start]} {
        set ::e2e_phase_start $now
        set ::e2e_phase_last $now
    }
    set delta [expr {($now - $::e2e_phase_last) / 1000.0}]
    set total [expr {($now - $::e2e_phase_start) / 1000.0}]
    puts [format "\[phase\] %-24s %6.1fs   (total %.1fs)" $label $delta $total]
    set ::e2e_phase_last $now
}

# Spawn a fresh `devm shell`, wait for the prompt, run one command,
# assert want_re appears before the next prompt, then exit the shell
# cleanly. Used by recreate-and-verify tests to inspect the new
# sandbox state after a teardown/stop recreate. test_name + label go
# into failure messages. Leaves the sandbox stopped on exit.
proc e2e_run_in_fresh_shell {test_name label devm command want_re} {
    spawn $devm shell
    set sid $spawn_id
    expect {
        -i $sid
        -re $::e2e_prompt_re { }
        timeout { e2e_fail $test_name "$label: fresh shell never reached prompt" }
        eof { e2e_fail $test_name "$label: fresh shell exited before prompt" }
    }
    send -i $sid "$command\r"
    expect {
        -i $sid
        -re $want_re { }
        timeout { e2e_fail $test_name "$label: did not see /$want_re/ after: $command" }
        eof { e2e_fail $test_name "$label: shell died running: $command" }
    }
    expect {
        -i $sid
        -re $::e2e_prompt_re { }
        timeout { e2e_fail $test_name "$label: no prompt after: $command" }
    }
    send -i $sid "exit\r"
    expect {
        -i $sid
        eof { }
        timeout { e2e_fail $test_name "$label: fresh shell did not exit" }
    }
}

proc e2e_pass {name} {
    puts "PASS: $name"
    exit 0
}

proc e2e_fail {name reason} {
    puts stderr "FAIL: $name: $reason"
    exit 1
}
