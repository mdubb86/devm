#!/usr/bin/env expect -f
source [file dirname [info script]]/lib/common.exp

set timeout 180
set test_name "10_reconcile_yes_stops"

# Cold start with a service carrying an env var (env change is a
# STOP+SHELL bucket change) plus a worker daemon for a reliable
# cold-start shape.
set yaml_extra {services:
  api:
    canonical: 8080
    env:
      LOG_LEVEL: "info"
  worker:
    startup:
      - command: ["sh", "-c", "while true; do sleep 60; done"]
        background: true
}
lassign [e2e_setup_workspace "rec-yes" $yaml_extra] sb ws
cd $ws

# Cold start (writes snapshot baseline).
spawn [e2e_devm_path] shell
set shell_id $spawn_id
expect {
    -i $shell_id
    -re $::e2e_prompt_re { }
    timeout { e2e_fail $test_name "shell never reached prompt" }
    eof { e2e_fail $test_name "shell exited before prompt" }
}

# Edit env LOG_LEVEL info → debug. This is a STOP+SHELL change.
set fd [open "$ws/devm.yaml" "r"]
set current [read $fd]
close $fd
regsub {LOG_LEVEL: "info"} $current {LOG_LEVEL: "debug"} new
set fd [open "$ws/devm.yaml" "w"]
puts -nonewline $fd $new
close $fd

# Run reconcile --yes from a separate process. It should execute the
# STOP+SHELL recreate: stop the sandbox (no shell relaunch). The
# command itself may exit non-zero in some flows; we assert on the
# resulting sandbox state, not reconcile's exit code.
catch {exec [e2e_devm_path] reconcile --yes} _

# The user shell must die (sandbox was stopped under it).
expect {
    -i $shell_id
    eof { }
    timeout { e2e_fail $test_name "user shell did not die after reconcile --yes recreate" }
}

# Sandbox should be stopped (reconcile does NOT relaunch a shell).
e2e_assert_sandbox_state $sb "stopped"

e2e_pass $test_name
