#!/usr/bin/env expect -f
source [file dirname [info script]]/lib/common.exp

set timeout 180
set test_name "12_ports_remove_change"

# Two ported services (api 8080 -> host 59080, web 3000 -> host 54000)
# plus a worker daemon for a reliable cold-start shape.
# port_offset is 51000 (set by e2e_setup_workspace).
set yaml_extra {services:
  api:
    canonical: 8080
  web:
    canonical: 3000
  worker:
    startup:
      - command: ["sh", "-c", "while true; do sleep 60; done"]
        background: true
}
lassign [e2e_setup_workspace "ports-rc" $yaml_extra] sb ws
cd $ws

# Cold start; keep the shell open so reconcile is a LIVE op.
spawn [e2e_devm_path] shell
set shell_id $spawn_id
expect {
    -i $shell_id
    -re $::e2e_prompt_re { }
    timeout { e2e_fail $test_name "shell never reached prompt" }
    eof { e2e_fail $test_name "shell exited before prompt" }
}

# Both ports published initially.
e2e_assert_ports_contain $sb "59080"
e2e_assert_ports_contain $sb "54000"

# Edit devm.yaml: remove `web` entirely (port remove) and change
# api 8080 -> 8081 (port change). New api host = 51000+8081 = 59081.
# string map does literal replacement; double-quoted patterns make \n
# real newlines (regsub brace-quoted replacements treat \n literally).
set fd [open "$ws/devm.yaml" "r"]
set current [read $fd]
close $fd
set current [string map [list \
    "  web:\n    canonical: 3000\n" "" \
    "    canonical: 8080\n" "    canonical: 8081\n" \
] $current]
set fd [open "$ws/devm.yaml" "w"]
puts -nonewline $fd $current
close $fd

# Reconcile (LIVE: unpublish web, unpublish old api, publish new api).
if {[catch {exec [e2e_devm_path] reconcile --yes} rc_out]} {
    e2e_fail $test_name "devm reconcile failed: $rc_out"
}

# New api port present; removed web port and old api port gone.
e2e_assert_ports_contain $sb "59081"
e2e_assert_ports_absent $sb "54000"
e2e_assert_ports_absent $sb "59080"

# User shell still alive (all LIVE; no restart).
send -i $shell_id "echo still-alive\r"
expect {
    -i $shell_id
    -re {still-alive} { }
    timeout { e2e_fail $test_name "user shell died after LIVE port reconcile" }
    eof { e2e_fail $test_name "user shell EOF after reconcile" }
}
expect {
    -i $shell_id
    -re $::e2e_prompt_re { }
    timeout { e2e_fail $test_name "no prompt after echo" }
}

send -i $shell_id "exit\r"
expect {
    -i $shell_id
    eof { }
    timeout { e2e_fail $test_name "shell did not exit" }
}
e2e_assert_sandbox_state $sb "stopped"

e2e_pass $test_name
